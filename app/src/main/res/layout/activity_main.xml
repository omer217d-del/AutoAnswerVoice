<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AutoAnswer Voice"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <!-- Ana aç/kapa düğmesi -->
        <Button
            android:id="@+id/btnToggle"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:text="KAPALI"
            android:textSize="20sp"
            android:textStyle="bold"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="32dp" />

        <!-- Durum bilgileri -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Durum: Bekleniyor"
            android:textColor="#AAAAAA"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvAccessibility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Erişilebilirlik: ❌"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvService"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Servis: ❌"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <!-- Aktif ses kaynağı -->
        <TextView
            android:id="@+id/tvAudioSource"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ses: varsayılan mesaj (message.mp3)"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Erişilebilirlik ayarları kısayolu -->
        <Button
            android:id="@+id/btnAccessibility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Erişilebilirliği Aç"
            android:backgroundTint="#333333"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp" />

        <!-- Ses kayıt bölümü -->
        <Button
            android:id="@+id/btnRecord"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎙 Ses Kaydı Yap"
            android:backgroundTint="#B71C1C"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvRecordStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
